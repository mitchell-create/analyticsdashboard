# Slack Bot — copy to .env and fill in values
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres.xxx:password@aws-1-us-east-2.pooler.supabase.com:5432/postgres
PORT=3001

# Optional: OpenAI API key for LLM fallback (flexible natural-language questions)
# Without this, only pattern-matched questions work
OPENAI_API_KEY=sk-your-openai-api-key

# GeoLift experiment agent: channel where results are posted automatically
SLACK_EXPERIMENT_CHANNEL_ID=C0ALS4UQBUY
