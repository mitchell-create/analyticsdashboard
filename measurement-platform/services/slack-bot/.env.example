# Slack Bot — copy to .env and fill in values
# Each client gets its own bot process with its own .env file.

# Client identifier — must match client_slug in the database
CLIENT_SLUG=your-client-slug

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres.xxx:password@aws-1-us-east-2.pooler.supabase.com:5432/postgres
PORT=3001

# Optional: OpenAI API key for LLM fallback, reports, and GeoLift agent
# Without this, only pattern-matched questions work
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: Use better models (recommended for GeoLift agent)
# OPENAI_MODEL=gpt-4o           # SQL/reports (default: gpt-4o-mini)
# OPENAI_AGENT_MODEL=gpt-4o     # GeoLift/experiment agent (default: gpt-4o)

# Multi-client: path to clients.json registry (see clients.example.json)
# If not set, falls back to single-client mode using SUPABASE_* vars above.
# CLIENT_REGISTRY_PATH=./clients.json
