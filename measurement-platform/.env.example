# measurement-platform — per-client env (Pattern B: 1 DB per client)
# Copy to .env and set values. Do not commit .env.

# Supabase (client warehouse) — analytics-dashboard example
SUPABASE_URL=https://xopsomagbnsnadxxhzhx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres.xopsomagbnsnadxxhzhx:[password]@aws-1-us-east-2.pooler.supabase.com:5432/postgres
SUPABASE_DB_HOST=aws-1-us-east-2.pooler.supabase.com
SUPABASE_DB_USER=postgres.xopsomagbnsnadxxhzhx
SUPABASE_DB_PASSWORD=

# dbt (same client DB)
# Use SUPABASE_DB_* above in profiles.yml or env vars

# Airbyte (optional — for Prefect sync check)
AIRBYTE_API_KEY=
AIRBYTE_WORKSPACE_ID=

# Metricool (optional — if syncing via custom job)
METRICOOL_API_KEY=

# Slack (bot + alerts)
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_ALERT_CHANNEL_ID=C...
# SLACK_BOT_USER_ID=U... (optional, for @mention filter)

# Prefect
PREFECT_API_URL=http://127.0.0.1:4200/api

# Optional: LLM for Slack Q&A (e.g. OpenAI)
# OPENAI_API_KEY=

# Metabase (for create_mvp_dashboards.py — optional)
# METABASE_URL=http://localhost:3000
# METABASE_EMAIL=admin@example.com
# METABASE_PASSWORD=...
# Or use API key: METABASE_API_KEY=...

# Optional: MCP servers (Metricool, Airbyte, Slack, Metabase)
# Not required for MVP.
